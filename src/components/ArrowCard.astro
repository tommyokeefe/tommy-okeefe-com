---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry:
    | CollectionEntry<"blog">
    | CollectionEntry<"projects">
    | CollectionEntry<"series">;
  index?: number;
};

const { entry, index = 0 } = Astro.props as {
  entry:
    | CollectionEntry<"blog">
    | CollectionEntry<"projects">
    | CollectionEntry<"series">;
  index?: number;
};

const accents = [
  { border: "border-l-accent dark:border-l-[#00BFBF]", gradientLight: "rgba(0,255,255,0.18)", gradientDark: "rgba(0,191,191,0.28)" },
  { border: "border-l-accent-magenta dark:border-l-[#BF00BF]", gradientLight: "rgba(255,0,255,0.18)", gradientDark: "rgba(191,0,191,0.28)" },
  { border: "border-l-accent-yellow dark:border-l-[#BFBF00]", gradientLight: "rgba(255,255,0,0.18)", gradientDark: "rgba(191,191,0,0.28)" },
] as const;
const { border: accentBorder, gradientLight, gradientDark } = accents[index % 3];
---

<a
  href={`/${entry.collection}/${entry.slug}`}
  class={`not-prose focus-visible:black group relative flex flex-nowrap rounded-lg border border-l-4 ${accentBorder} border-black/15 px-4 py-3 pr-10 transition-colors duration-300 ease-in-out hover:text-black focus-visible:bg-black/5 dark:border-white/20 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white`}
  style={`background: linear-gradient(to right, ${gradientLight} 0%, transparent 60%);`}
  data-gradient-light={gradientLight}
  data-gradient-dark={gradientDark}
>
  <div class="flex flex-1 flex-col truncate">
    <div class="text-wrap font-serif text-xl font-semibold">
      {entry.data.title}
    </div>
    <div class="text-wrap text-sm">
      {entry.data.description}
    </div>
  </div>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute right-2 top-1/2 size-5 -translate-y-1/2 fill-none stroke-current stroke-2"
  >
    <line
      x1="5"
      y1="12"
      x2="19"
      y2="12"
      class="translate-x-3 scale-x-0 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-hover:scale-x-100 group-focus-visible:translate-x-0 group-focus-visible:scale-x-100"
    ></line>
    <polyline
      points="12 5 19 12 12 19"
      class="-translate-x-1 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-focus-visible:translate-x-0"
    ></polyline>
  </svg>
</a>

<script>
  function applyCardGradients() {
    const dark = document.documentElement.classList.contains("dark");
    document.querySelectorAll<HTMLElement>("a[data-gradient-light]").forEach((el) => {
      const color = dark ? el.dataset.gradientDark : el.dataset.gradientLight;
      el.style.background = `linear-gradient(to right, ${color} 0%, transparent 60%)`;
    });
  }

  document.addEventListener("astro:page-load", applyCardGradients);

  // Also react when the theme toggles without navigation
  const observer = new MutationObserver(applyCardGradients);
  observer.observe(document.documentElement, { attributeFilter: ["class"] });
</script>
