---
import TableOfContentsHeading from "./TableOfContentsHeading.astro";

// https://kld.dev/building-table-of-contents/
const { headings } = Astro.props;
const toc = buildToc(headings);

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

function buildToc(headings: Heading[]) {
  const toc: Heading[] = [];
  const parentHeadings = new Map();
  headings.forEach((h) => {
    const heading = { ...h, subheadings: [] };
    parentHeadings.set(heading.depth, heading);
    if (heading.depth === 2) {
      toc.push(heading);
    } else {
      parentHeadings.get(heading.depth - 1).subheadings.push(heading);
    }
  });
  return toc;
}
---

<details
  open
  class="animate rounded-lg border border-black/15 dark:border-white/20"
>
  <summary data-toc-summary class="font-serif text-lg">Table of Contents</summary>
  <nav class="">
    <ul class="py-3">
      {toc.map((heading) => <TableOfContentsHeading heading={heading} />)}
    </ul>
  </nav>
</details>

<style>
  summary {
    @apply cursor-pointer rounded-t-lg px-3 py-1.5 font-medium transition-colors;
  }
</style>

<script>
  const accents = [
    { bgLight: "rgba(0,255,255,0.18)", bgDark: "rgba(0,191,191,0.28)", borderLight: "#00FFFF", borderDark: "#00BFBF" },
    { bgLight: "rgba(255,0,255,0.18)", bgDark: "rgba(191,0,191,0.28)", borderLight: "#FF00FF", borderDark: "#BF00BF" },
    { bgLight: "rgba(255,255,0,0.18)", bgDark: "rgba(191,191,0,0.28)", borderLight: "#FFFF00", borderDark: "#BFBF00" },
  ];

  function applyTocAccent() {
    const dark = document.documentElement.classList.contains("dark");
    document.querySelectorAll<HTMLElement>("[data-toc-summary]").forEach((el) => {
      if (!el.dataset.accentIndex) {
        el.dataset.accentIndex = String(Math.floor(Math.random() * 3));
      }
      const accent = accents[Number(el.dataset.accentIndex)];
      el.style.backgroundColor = dark ? accent.bgDark : accent.bgLight;
      el.style.borderBottom = `1px solid ${dark ? accent.borderDark : accent.borderLight}`;
    });
  }

  document.addEventListener("astro:page-load", applyTocAccent);

  const observer = new MutationObserver(applyTocAccent);
  observer.observe(document.documentElement, { attributeFilter: ["class"] });
</script>
