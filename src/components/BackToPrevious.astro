---
type Props = {
  href: string;
};

const { href } = Astro.props;
---

<a
  href={href}
  data-back-to-previous
  class="not-prose group relative flex w-fit flex-nowrap rounded border border-l-4 py-1.5 pl-7 pr-3 transition-colors duration-300 ease-in-out hover:text-black focus-visible:text-black dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    class="absolute left-2 top-1/2 size-4 -translate-y-1/2 fill-none stroke-current stroke-2"
  >
    <line
      x1="5"
      y1="12"
      x2="19"
      y2="12"
      class="translate-x-2 scale-x-0 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-hover:scale-x-100 group-focus-visible:translate-x-0 group-focus-visible:scale-x-100"
    ></line>
    <polyline
      points="12 5 5 12 12 19"
      class="translate-x-1 transition-transform duration-300 ease-in-out group-hover:translate-x-0 group-focus-visible:translate-x-0"
    ></polyline>
  </svg>
  <div class="text-sm">
    <slot />
  </div>
</a>

<script>
  import { getHeaderAccent } from "@lib/accents";

  function applyBackToPreviousAccent() {
    const dark = document.documentElement.classList.contains("dark");
    const accent = getHeaderAccent();
    document
      .querySelectorAll<HTMLElement>("[data-back-to-previous]")
      .forEach((el) => {
        el.style.borderColor = dark
          ? "rgba(255,255,255,0.2)"
          : "rgba(0,0,0,0.15)";
        el.style.borderLeftColor = dark ? accent.dark : accent.light;
        el.style.background = `linear-gradient(to right, ${dark ? accent.gradientDark : accent.gradientLight} 0%, transparent 60%)`;
      });
  }

  document.addEventListener("astro:page-load", applyBackToPreviousAccent);

  const observer = new MutationObserver(applyBackToPreviousAccent);
  observer.observe(document.documentElement, { attributeFilter: ["class"] });
</script>
