---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";

const accents = ["cyan", "magenta", "yellow"];
const accent = accents[Math.floor(Math.random() * 3)];
---

<header transition:persist data-header-accent={accent}>
  <Container>
    <div class="flex flex-wrap justify-between gap-y-2">
      <Link href="/" underline={false}>
        <div class="font-serif text-xl font-semibold [text-shadow:0_2px_3px_rgb(255_255_255/0.9)] dark:[text-shadow:0_2px_3px_rgb(0_0_0/0.6)] md:text-3xl">
          {SITE.TITLE}
        </div>
      </Link>
      <nav class="flex items-center gap-1 [&_a]:decoration-black/30 [&_a]:hover:decoration-black/50 [&_a]:hover:text-black [&_a]:dark:decoration-white/50 [&_a]:dark:hover:decoration-white/70 [&_a]:dark:hover:text-white">
        <Link href="/blog">blog</Link>
        <span>
          {`/`}
        </span>
        <Link href="/rss.xml">rss</Link>
        <span>
          {`/`}
        </span>
        <!--         <Link href="/projects">projects</Link>
        <span>
          {`/`}
        </span> -->
        <button
          id="magnifying-glass"
          aria-label="Search"
          class="flex items-center rounded border border-accent bg-black/5 px-2 py-1 text-black transition-colors duration-300 ease-in-out hover:bg-black/10 focus-visible:bg-black/10 dark:border-[#00BFBF] dark:bg-white/5 dark:text-white dark:hover:bg-white/10 dark:focus-visible:bg-white/10"
        >
          <svg
            height="16"
            stroke-linejoin="round"
            viewBox="0 0 16 16"
            width="16"
            style="color: currentcolor;"
            ><path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M3.5 7C3.5 5.067 5.067 3.5 7 3.5C8.933 3.5 10.5 5.067 10.5 7C10.5 7.88461 10.1718 8.69256 9.63058 9.30876L9.30876 9.63058C8.69256 10.1718 7.88461 10.5 7 10.5C5.067 10.5 3.5 8.933 3.5 7ZM9.96544 11.0261C9.13578 11.6382 8.11014 12 7 12C4.23858 12 2 9.76142 2 7C2 4.23858 4.23858 2 7 2C9.76142 2 12 4.23858 12 7C12 8.11014 11.6382 9.13578 11.0261 9.96544L14.0303 12.9697L14.5607 13.5L13.5 14.5607L12.9697 14.0303L9.96544 11.0261Z"
              fill="currentColor"></path></svg
          >
          &nbsp;search
        </button>
      </nav>
    </div>
  </Container>
</header>

<script>
  function updateHeaderAccent() {
    const accents = ["cyan", "magenta", "yellow"];
    const accent = accents[Math.floor(Math.random() * 3)];
    document.querySelector("header")?.setAttribute("data-header-accent", accent);
  }

  // Only re-roll on navigation, not on initial page load/refresh
  document.addEventListener("astro:after-swap", updateHeaderAccent);
</script>
