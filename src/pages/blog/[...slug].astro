---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import { slugifyTag } from "@lib/tags";
import BackToPrevious from "@components/BackToPrevious.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import ArrowCard from "@components/ArrowCard.astro";
import BlueskyCommentsSection from "@components/BlueskyComments";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function getNextPost() {
  let postIndex;
  for (const post of posts) {
    if (post.slug === Astro.params.slug) {
      postIndex = posts.indexOf(post);
      return posts[postIndex + 1];
    }
  }
}

const [series] = (await getCollection("series")).filter(
  (series) => series.slug === "les-miserables",
);

function getPrevPost() {
  let postIndex;
  for (const post of posts) {
    if (post.slug === Astro.params.slug) {
      postIndex = posts.indexOf(post);
      return posts[postIndex - 1];
    }
  }
}

const nextPost = getNextPost();
const prevPost = getPrevPost();

const post = Astro.props;
const { Content, headings } = await post.render();
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <Container>
    <div class="animate">
      <BackToPrevious href="/blog">Back to blog</BackToPrevious>
    </div>
    <div class="my-10 space-y-1">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body)}
        </div>
      </div>
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="animate flex flex-wrap items-center gap-2">
            <strong class="text-sm font-semibold">
              {post.data.tags.length > 1 ? "Tags:" : "Tag:"}
            </strong>
            {post.data.tags.map((tag) => (
              <a
                class="rounded-full bg-gray-200 px-2 py-0.5 text-xs uppercase text-gray-800 hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-100 hover:dark:bg-gray-600"
                href={`/tags/${slugifyTag(tag)}`}
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
      <h1 class="animate text-3xl font-semibold text-black dark:text-white">
        {post.data.title}
      </h1>
    </div>
    {
      post.data.image && (
        <div class="animate my-6">
          <img
            src={post.data.image}
            alt={post.data.imageAlt ?? post.data.title}
            class="w-full rounded-lg object-cover"
          />
        </div>
      )
    }
    <Container>
      {headings.length > 0 && <TableOfContents headings={headings} />}
      <article class="animate">
        <Content />
        {
          post.data.blueskyPostUri && (
            <div class="mt-12">
              <BlueskyCommentsSection
                client:visible
                uri={post.data.blueskyPostUri}
              />
            </div>
          )
        }
        <div class="mt-12">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </div>
        {
          post.data.series == "lm" && (
            <div class="mt-12">
              <h2>See the rest of the series</h2>
              <ArrowCard entry={series} />
            </div>
          )
        }
      </article>
    </Container>
  </Container>
</Layout>
