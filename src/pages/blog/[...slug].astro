---
import { type CollectionEntry, getCollection, getEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import { slugifyTag } from "@lib/tags";
import BackToPrevious from "@components/BackToPrevious.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import ArrowCard from "@components/ArrowCard.astro";
import BlueskyCommentsSection from "@components/BlueskyComments";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post) => import.meta.env.PROD ? !post.data.draft : true)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: { post, prevPost: posts[index + 1], nextPost: posts[index - 1] },
  }));
}
type Props = {
  post: CollectionEntry<"blog">;
  prevPost: CollectionEntry<"blog"> | undefined;
  nextPost: CollectionEntry<"blog"> | undefined;
};

const { post, prevPost, nextPost } = Astro.props;

const seriesEntry = post.data.series
  ? await getEntry(post.data.series)
  : undefined;

const { Content, headings } = await post.render();
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image?.src}
>
  <Container>
    <div class="animate">
      <BackToPrevious href={seriesEntry ? `/series/${seriesEntry.slug}` : "/blog"}>
        {seriesEntry ? `Back to ${seriesEntry.data.title}` : "Back to blog"}
      </BackToPrevious>
    </div>
    <div class="my-10 space-y-1">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body)}
        </div>
      </div>
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="animate flex flex-wrap items-center gap-2" data-tags>
            <strong class="text-sm font-semibold">
              {post.data.tags.length > 1 ? "Tags:" : "Tag:"}
            </strong>
            {post.data.tags.map((tag) => (
              <a
                data-tag-pill
                class="rounded-full px-2 py-0.5 text-xs uppercase font-semibold"
                href={`/tags/${slugifyTag(tag)}`}
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
      <h1 class="animate text-3xl font-semibold text-black dark:text-white">
        {post.data.title}
      </h1>
    </div>
    {
      post.data.image && (
        <div class="animate my-6">
          <img
            src={post.data.image?.src}
            alt={post.data.imageAlt ?? post.data.title}
            class="w-full rounded-lg object-cover"
          />
        </div>
      )
    }
    <Container>
      {headings.length > 0 && <TableOfContents headings={headings} />}
      <article class="animate">
        <Content />
        {
          post.data.blueskyPostUri && (
            <div class="mt-12">
              <BlueskyCommentsSection
                client:visible
                uri={post.data.blueskyPostUri}
              />
            </div>
          )
        }
        <div class="mt-12">
          <PostNavigation prevPost={prevPost} nextPost={nextPost} />
        </div>
        {
          seriesEntry && (
            <div class="mt-24">
              <h2>See the rest of the series</h2>
              <div data-series-card>
                <ArrowCard entry={seriesEntry} />
              </div>
            </div>
          )
        }
      </article>
    </Container>
  </Container>
</Layout>

<script>
  const ACCENTS: Record<string, { light: string; dark: string }> = {
    cyan:    { light: "#00FFFF", dark: "#00BFBF" },
    magenta: { light: "#FF00FF", dark: "#BF00BF" },
    yellow:  { light: "#FFFF00", dark: "#BFBF00" },
  };

  function getHeaderAccent() {
    const name = document.querySelector("header")?.dataset.headerAccent ?? "cyan";
    return ACCENTS[name] ?? ACCENTS.cyan;
  }

  function applyTagAccents() {
    const dark = document.documentElement.classList.contains("dark");
    const accent = getHeaderAccent();
    const bg = dark ? accent.dark : accent.light;
    document.querySelectorAll<HTMLElement>("[data-tags]").forEach((container) => {
      container.querySelectorAll<HTMLElement>("[data-tag-pill]").forEach((pill) => {
        pill.style.backgroundColor = bg;
        pill.style.color = "black";
      });
    });
  }

  function applyBlockquoteAccents() {
    const dark = document.documentElement.classList.contains("dark");
    const accent = getHeaderAccent();
    const color = dark ? accent.dark : accent.light;
    document.querySelectorAll<HTMLElement>("article blockquote").forEach((el) => {
      el.style.borderLeftColor = color;
      el.style.background = dark
        ? `linear-gradient(to right, ${color}22, transparent)`
        : `linear-gradient(to right, ${color}55, transparent)`;
    });
  }

  function applySeriesCardAccent() {
    const dark = document.documentElement.classList.contains("dark");
    const accent = getHeaderAccent();
    const color = dark ? accent.dark : accent.light;
    const gradientColor = dark
      ? `${accent.dark}47`   // ~28% opacity (0x47)
      : `${accent.light}2E`; // ~18% opacity (0x2E)
    document.querySelectorAll<HTMLElement>("[data-series-card] a").forEach((el) => {
      // Mark the element so ArrowCard's generic gradient sweep skips it
      el.dataset.accentOverride = "true";
      el.style.borderLeftColor = color;
      el.style.background = `linear-gradient(to right, ${gradientColor} 0%, transparent 60%)`;
    });
  }

  function applyAccents() {
    applyTagAccents();
    applyBlockquoteAccents();
    applySeriesCardAccent();
  }

  document.addEventListener("astro:page-load", applyAccents);

  const observer = new MutationObserver(applyAccents);
  observer.observe(document.documentElement, { attributeFilter: ["class"] });
</script>
