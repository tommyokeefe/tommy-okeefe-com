---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import BackToPrevious from "@components/BackToPrevious.astro";
import { getCurrentBook } from "@lib/reading";

const book = await getCurrentBook();

const storyGraphLabels: Record<string, string> = {
  plotOrCharacterDriven: "Plot or Character Driven",
  strongCharacterDevelopment: "Strong Character Development",
  loveableCharacters: "Loveable Characters",
  diverseCast: "Diverse Cast of Characters",
  flawsAMainFocus: "Flaws of Characters a Main Focus",
};

const storyGraphEntries = Object.entries(book.storygraph) as [
  keyof typeof book.storygraph,
  string,
][];

type StarType = "full" | "half" | "empty";
const stars: StarType[] = Array.from({ length: 5 }, (_, i) => {
  if (i + 1 <= book.rating) return "full";
  if (i + 0.5 < book.rating + 0.25) return "half";
  return "empty";
});
---

<Layout
  title="Most Recent Read"
  description={`Most recent read: ${book.title} by ${book.author}.`}
>
  <Container>
    <div class="space-y-8">
      <div class="animate">
        <BackToPrevious href="/">Back home</BackToPrevious>
      </div>

      <div class="animate space-y-2">
        <h1
          class="font-serif text-3xl font-semibold text-black dark:text-white"
        >
          Most Recent Read
        </h1>
        <p class="text-black/60 dark:text-white/60">
          The last book I finished, with my notes and ratings.
        </p>
      </div>

      <div class="animate space-y-6">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
          {
            book.coverUrl && (
              <img
                src={book.coverUrl}
                alt={`${book.title} by ${book.author}`}
                class="h-48 w-36 flex-shrink-0 rounded-lg object-cover shadow-md"
                loading="eager"
              />
            )
          }
          <div class="space-y-3">
            <div>
              <h2
                class="font-serif text-2xl font-semibold text-black dark:text-white"
              >
                {book.title}
              </h2>
              <p class="text-lg text-black/70 dark:text-white/70">
                {book.author}
              </p>
            </div>

            <!-- Star rating -->
            <div class="flex items-center gap-1.5">
              <span class="text-sm font-medium text-black dark:text-white">
                {book.rating} / 5
              </span>
              <div
                class="flex gap-0.5"
                aria-label={`${book.rating} out of 5 stars`}
              >
                {
                  stars.map((type) => (
                    <svg
                      aria-hidden="true"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      class="size-4"
                    >
                      <polygon
                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
                        class={
                          type === "full"
                            ? "fill-black stroke-none dark:fill-white"
                            : type === "half"
                              ? "fill-black/40 stroke-black stroke-1 dark:fill-white/40 dark:stroke-white"
                              : "fill-none stroke-black stroke-1 opacity-30 dark:stroke-white"
                        }
                      />
                    </svg>
                  ))
                }
              </div>
            </div>

            <!-- Tags -->
            {
              book.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {book.tags.map((tag) => (
                    <span class="rounded-full border border-black/15 px-2.5 py-0.5 text-xs text-black/60 dark:border-white/20 dark:text-white/60">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }

            <!-- Links -->
            {
              book.openLibraryUrl && (
                <div class="flex flex-wrap gap-2 pt-1">
                  <Link href={book.openLibraryUrl} external>
                    View on Open Library
                  </Link>
                </div>
              )
            }
          </div>
        </div>

        <!-- StoryGraph metadata -->
        <div
          class="rounded-lg border border-black/10 bg-black/[0.02] p-4 dark:border-white/10 dark:bg-white/[0.02]"
        >
          <p
            class="mb-3 text-xs font-semibold uppercase tracking-wider text-black/40 dark:text-white/40"
          >
            StoryGraph Metadata
          </p>
          <dl class="space-y-1.5">
            {
              storyGraphEntries.map(([key, value]) => (
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-0.5 text-sm">
                  <dt class="text-black/60 dark:text-white/60">
                    {storyGraphLabels[key]}
                  </dt>
                  <dd class="font-medium text-black dark:text-white">
                    {value}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>
    </div>
  </Container>
</Layout>
