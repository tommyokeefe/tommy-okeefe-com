---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";

export async function getStaticPaths() {
  const allSeries = await getCollection("series");
  return allSeries.map((s) => ({ params: { slug: s.slug }, props: s }));
}

type Props = CollectionEntry<"series">;

const slug = Astro.params.slug;
const seriesEntry = Astro.props;

// gather posts belonging to this series, sort by series frontmatter `order` (default: asc)
const order = seriesEntry.data.order ?? "asc";
const posts = (await getCollection("blog"))
  .filter(
    (p) =>
      p.data.series?.slug === slug &&
      (import.meta.env.PROD ? !p.data.draft : true),
  )
  .sort((a, b) =>
    order === "asc"
      ? a.data.date.valueOf() - b.data.date.valueOf()
      : b.data.date.valueOf() - a.data.date.valueOf(),
  );

const { Content } = await seriesEntry.render();

// toggle state will be handled client-side
---

<Layout
  title={seriesEntry.data.title}
  description={seriesEntry.data.description}
  image={seriesEntry.data.image?.src}
>
  <Container>
    <aside data-pagefind-ignore>
      <h1 class="text-3xl font-semibold text-black dark:text-white">
        {seriesEntry.data.title}
      </h1>
      <div class="space-y-10">
        <div class="space-y-4">
          <br />
          <Content />
          <p>
            <Link href={`/series/${slug}/rss.xml`}
              >Subscribe to this series RSS feed</Link
            >
          </p>
          <section class="animate space-y-4">
            <div>
              <ul id="seriesList" class="not-prose flex flex-col gap-4">
                {
                  posts.map((post, i) => (
                    <li>
                      <ArrowCard entry={post} index={i} />
                    </li>
                  ))
                }
              </ul>
            </div>
          </section>
        </div>
      </div>
    </aside>
  </Container>
</Layout>
