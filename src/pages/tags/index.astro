---
import { getTagsWithCounts, slugifyTag } from "@lib/tags";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";

const tagsWithCounts = await getTagsWithCounts();

const minSize = 0.85;
const maxSize = 2.5;

const counts = tagsWithCounts.map((t) => t.count);
const minCount = Math.min(...counts);
const maxCount = Math.max(...counts);
const range = maxCount - minCount || 1;

function fontSize(count: number): string {
  const size = minSize + ((count - minCount) / range) * (maxSize - minSize);
  return `${size.toFixed(3)}rem`;
}
---

<Layout title="Tags" description="Browse posts by tag">
  <Container>
    <aside data-pagefind-ignore>
      <h1 class="mb-10 text-3xl font-semibold text-black dark:text-white">
        Tags
      </h1>
      {
        tagsWithCounts.length === 0 ? (
          <p>No tags have been added yet.</p>
        ) : (
          <div class="flex flex-wrap items-baseline gap-x-4 gap-y-3">
            {tagsWithCounts.map(({ tag, count }) => (
              <a
                href={`/tags/${slugifyTag(tag)}`}
                style={`font-size: ${fontSize(count)}`}
                class="text-black/70 underline decoration-dotted underline-offset-2 transition-colors duration-200 hover:text-black dark:text-white/70 dark:hover:text-white"
                title={`${count} post${count === 1 ? "" : "s"}`}
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </aside>
  </Container>
</Layout>
